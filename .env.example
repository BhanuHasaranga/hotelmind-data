# ─────────────────────────────────────────────────────────────────────────────
# HotelMind Data — Environment Variables
# Copy to .env and fill in values before running.
# ─────────────────────────────────────────────────────────────────────────────

# ── Source (Operational) Database ─────────────────────────────────────────────
SOURCE_DB_HOST=localhost
SOURCE_DB_PORT=5432
SOURCE_DB_NAME=hotelmind_db
SOURCE_DB_USER=hotelmind
SOURCE_DB_PASSWORD=hotelmind_secret

# ── Warehouse (Analytical) Database ───────────────────────────────────────────
# In local dev this is a separate DB on port 5433 (see docker-compose.yml).
# In production point this at Redshift or a dedicated RDS instance.
WAREHOUSE_DB_HOST=localhost
WAREHOUSE_DB_PORT=5433
WAREHOUSE_DB_NAME=hotelmind_warehouse
WAREHOUSE_DB_USER=hotelmind_dw
WAREHOUSE_DB_PASSWORD=hotelmind_dw_secret

# ── MinIO / S3 Data Lake ──────────────────────────────────────────────────────
# In local dev MinIO runs at :9000.
# In production set S3_ENDPOINT_URL="" and rely on AWS credentials.
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=hotelmind_minio
S3_SECRET_KEY=hotelmind_minio_secret
S3_BUCKET_RAW=hotelmind-raw
S3_BUCKET_PROCESSED=hotelmind-processed

# ── dbt ───────────────────────────────────────────────────────────────────────
DBT_PROFILES_DIR=./dbt
DBT_PROJECT_DIR=./dbt
DBT_TARGET=dev

# ── Airflow ───────────────────────────────────────────────────────────────────
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@localhost:5434/airflow
AIRFLOW__CORE__FERNET_KEY=your-fernet-key-here
AIRFLOW__WEBSERVER__SECRET_KEY=your-webserver-secret-here
AIRFLOW_UID=50000

# ── Pipeline ──────────────────────────────────────────────────────────────────
# How many days back to look on first run (before any watermark exists)
ETL_INITIAL_LOOKBACK_DAYS=365
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
